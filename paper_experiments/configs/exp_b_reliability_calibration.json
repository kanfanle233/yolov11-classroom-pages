{
  "branch_name": "exp_b_reliability_calibration",
  "objective": "Validate whether UQ-gated reliability and temperature calibration improve robust recognition trustworthiness under noisy samples.",
  "experiment_type": "reliability_calibration",
  "data_mode": "sample",
  "inputs": {
    "event_queries": "paper_experiments/samples/event_queries.sample.jsonl",
    "actions": "paper_experiments/samples/actions_dual.sample.jsonl",
    "pose_uq": "paper_experiments/samples/pose_tracks_smooth_uq.sample.jsonl",
    "reference_labels": "paper_experiments/samples/reference_labels.reliability.sample.jsonl"
  },
  "align_params": {
    "fps": 25.0,
    "base_window": 1.0,
    "alpha_motion": 1.2,
    "beta_uq": 0.8,
    "min_window": 0.6,
    "max_window": 3.5,
    "topk": 8
  },
  "dual_verifier_params": {
    "keep_all_candidates": 1,
    "validate": 1
  },
  "reliability_eval_params": {
    "split": "exp_b_smoke",
    "score_threshold": 0.6,
    "low_uq_threshold": 0.4,
    "high_uq_threshold": 0.55,
    "num_bins": 10,
    "pseudo_match_threshold": 0.8
  }
}
