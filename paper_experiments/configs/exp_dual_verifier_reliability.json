{
  "branch_name": "exp_dual_verifier_reliability",
  "objective": "Run dual verification and report reliability metrics with calibration outputs on smoke data.",
  "experiment_type": "dual_verifier",
  "data_mode": "sample",
  "inputs": {
    "event_queries": "paper_experiments/samples/event_queries.sample.jsonl",
    "actions": "paper_experiments/samples/actions_dual.sample.jsonl",
    "pose_uq": "paper_experiments/samples/pose_tracks_smooth_uq.sample.jsonl"
  },
  "align_params": {
    "fps": 25.0,
    "base_window": 1.0,
    "alpha_motion": 1.2,
    "beta_uq": 0.8,
    "min_window": 0.6,
    "max_window": 3.5,
    "topk": 8
  },
  "dual_verifier_params": {
    "keep_all_candidates": 0,
    "validate": 1
  },
  "eval_params": {
    "split": "smoke",
    "target_field": "auto"
  },
  "calibration_params": {
    "split": "smoke",
    "target_field": "auto",
    "prob_field": "p_match",
    "num_bins": 10,
    "disable_temperature_scaling": 0
  }
}

