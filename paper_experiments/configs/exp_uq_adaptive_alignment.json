{
  "branch_name": "exp_uq_adaptive_alignment",
  "objective": "Evaluate uncertainty-driven adaptive alignment behavior on sample event/action streams.",
  "experiment_type": "uq_alignment",
  "data_mode": "sample",
  "inputs": {
    "event_queries": "paper_experiments/samples/event_queries.sample.jsonl",
    "actions": "paper_experiments/samples/actions_dual.sample.jsonl",
    "pose_uq": "paper_experiments/samples/pose_tracks_smooth_uq.sample.jsonl"
  },
  "align_params": {
    "fps": 25.0,
    "base_window": 1.0,
    "alpha_motion": 1.2,
    "beta_uq": 0.8,
    "min_window": 0.6,
    "max_window": 3.5,
    "topk": 8
  }
}

