{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "paper_experiments/gold/gold_events.real.schema.json",
  "title": "Real Classroom Gold Event Record",
  "description": "Schema for one JSONL row in gold_events.real.jsonl. Manual gold fields are required.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "case_id",
    "view_code",
    "suggested_event_id",
    "suggested_track_id",
    "suggested_action",
    "suggested_time_window",
    "suggested_label",
    "gold_track_id",
    "gold_action",
    "gold_start",
    "gold_end",
    "match_label",
    "noise_type",
    "occlusion_level",
    "asr_quality",
    "annotator",
    "review_status"
  ],
  "properties": {
    "case_id": {
      "type": "string",
      "minLength": 1
    },
    "view_code": {
      "type": "string",
      "enum": ["front", "rear", "teacher", "top1", "top2"]
    },
    "suggested_event_id": {
      "type": "string"
    },
    "suggested_track_id": {
      "oneOf": [
        { "type": "integer" },
        { "type": "string" },
        { "type": "null" }
      ]
    },
    "suggested_action": {
      "type": "string"
    },
    "suggested_time_window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": {
          "oneOf": [
            { "type": "number" },
            { "type": "null" }
          ]
        },
        "end": {
          "oneOf": [
            { "type": "number" },
            { "type": "null" }
          ]
        }
      }
    },
    "suggested_label": {
      "oneOf": [
        {
          "type": "string",
          "enum": ["match", "mismatch", "uncertain", "unknown"]
        },
        { "type": "null" }
      ]
    },
    "gold_track_id": {
      "oneOf": [
        { "type": "integer" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "gold_action": {
      "type": "string",
      "minLength": 1
    },
    "gold_start": {
      "type": "number"
    },
    "gold_end": {
      "type": "number"
    },
    "match_label": {
      "type": "string",
      "enum": ["match", "mismatch", "uncertain"]
    },
    "noise_type": {
      "type": "string",
      "enum": [
        "none",
        "asr_empty",
        "asr_noise",
        "occlusion",
        "multi_person_ambiguity",
        "camera_angle",
        "motion_blur",
        "other"
      ]
    },
    "occlusion_level": {
      "type": "string",
      "enum": ["none", "low", "medium", "high"]
    },
    "asr_quality": {
      "type": "string",
      "enum": ["empty", "low", "medium", "high", "not_applicable"]
    },
    "annotator": {
      "type": "string",
      "minLength": 1
    },
    "review_status": {
      "type": "string",
      "enum": ["draft", "peer_reviewed", "adjudicated", "rejected"]
    },
    "notes": {
      "type": "string"
    }
  }
}
