{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/paper_experiments/gold/gold_events.schema.json",
  "title": "gold_events_record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "case_id",
    "video_id",
    "query_id",
    "track_id",
    "event_start",
    "event_end",
    "query_text",
    "gold_action",
    "gold_match",
    "gold_alignment_valid",
    "gold_candidate_track_id",
    "visual_noise_level",
    "occlusion_level",
    "asr_noise_level",
    "time_shift_level",
    "fallback_allowed",
    "split",
    "annotator_id",
    "annotation_quality"
  ],
  "properties": {
    "case_id": { "type": "string", "minLength": 1 },
    "video_id": { "type": "string", "minLength": 1 },
    "frame_id": { "type": "integer", "minimum": 0 },
    "timestamp": { "type": "number", "minimum": 0 },
    "query_id": { "type": "string", "minLength": 1 },
    "track_id": { "type": "integer", "minimum": -1 },
    "event_start": { "type": "number", "minimum": 0 },
    "event_end": { "type": "number", "minimum": 0 },
    "query_text": { "type": "string", "minLength": 1 },
    "gold_action": {
      "type": ["string", "null"],
      "description": "人工标注动作标签。待标注时可为 null"
    },
    "gold_match": {
      "type": ["boolean", "null"],
      "description": "候选轨迹是否与 query 匹配。待标注时可为 null"
    },
    "gold_alignment_valid": {
      "type": ["boolean", "null"],
      "description": "时间对齐是否有效。待标注时可为 null"
    },
    "gold_candidate_track_id": {
      "type": ["integer", "null"],
      "minimum": -1,
      "description": "金标准候选轨迹 ID；无有效候选时可为 null"
    },
    "visual_noise_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "unknown"]
    },
    "occlusion_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "unknown"]
    },
    "asr_noise_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "unknown"]
    },
    "time_shift_level": {
      "type": "string",
      "enum": ["none", "small", "medium", "large", "unknown"]
    },
    "fallback_allowed": {
      "type": "boolean",
      "description": "该样本是否允许在推理阶段触发 fallback"
    },
    "split": {
      "type": "string",
      "enum": ["train", "dev", "test", "demo"]
    },
    "annotator_id": { "type": "string", "minLength": 1 },
    "annotation_quality": {
      "type": "string",
      "enum": ["pending", "single_pass", "double_checked", "adjudicated", "final"]
    },
    "negative_type": {
      "type": ["string", "null"],
      "enum": ["positive", "temporal_shift", "semantic_mismatch", "hard_negative", null]
    },
    "object_evidence_tags": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "demo_candidate": {
      "type": "boolean",
      "default": false
    },
    "notes": {
      "type": "string"
    }
  },
  "anyOf": [
    { "required": ["frame_id"] },
    { "required": ["timestamp"] }
  ]
}
