{
  "schema_version": "2026-04-16",
  "type": "case_video_level_split_template",
  "description": "样例 split，仅演示结构；非正式划分结果。",
  "rules": {
    "unit": "case_id + video_id",
    "no_event_random_split": true,
    "no_cross_split_video": true,
    "no_train_test_leakage": true,
    "demo_from_dev_or_test_only": true,
    "smoke_sample_not_gold": true
  },
  "splits": {
    "train": [
      { "case_id": "case_train_001", "video_id": "rear__001" },
      { "case_id": "case_train_002", "video_id": "rear__002" }
    ],
    "dev": [
      { "case_id": "case_dev_001", "video_id": "front__003" }
    ],
    "test": [
      { "case_id": "case_test_002", "video_id": "teacher__002" },
      { "case_id": "case_test_003", "video_id": "top1__004" }
    ],
    "demo": [
      { "case_id": "case_dev_001", "video_id": "front__003", "source_split": "dev" },
      { "case_id": "case_test_003", "video_id": "top1__004", "source_split": "test" }
    ]
  },
  "leakage_checks": [
    "同一 video_id 不得同时出现在 train 与 dev/test",
    "同一 case_id 不得跨 split 重复",
    "query_id 在同一视频源上不得跨 split 复用",
    "demo 仅可引用 dev/test 样本，不得回流 train"
  ]
}
